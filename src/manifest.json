{
  "manifest_version": 3,
  "name": "en.ke — URL Shortener & QR Codes",
  "short_name": "en.ke",
  "version": "1.0.2",
  "description": "Shorten URLs, generate QR codes, and manage links with en.ke — all without leaving your current page.",
  "minimum_chrome_version": "108",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "en.ke - Shorten this page"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.en.ke/*",
    "https://user.zenkee.com/*",
    "https://www.en.ke/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.en.ke/*"],
      "js": ["src/content/auth-bridge.ts"],
      "run_at": "document_end"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://www.en.ke/*"
    ]
  }
}
