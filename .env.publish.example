# ── Chrome Web Store Publish Credentials ──
#
# Reuse your existing Google Cloud project (zenkee).
# Just enable the "Chrome Web Store API" on it,
# then create an OAuth 2.0 Client (Web application).

# From Google Cloud Console → APIs & Services → Credentials
CLIENT_ID=
CLIENT_SECRET=

# From OAuth 2.0 Playground (see docs/oauth-setup.md)
REFRESH_TOKEN=

# From Chrome Web Store Developer Dashboard
# https://chrome.google.com/webstore/devconsole
EXTENSION_ID=

# From Developer Dashboard → Publisher → Settings
# (looks like a long hex string)
PUBLISHER_ID=
